# .env.example
# 이 파일은 "어떤 키가 필요한지" 알려주는 템플릿. 깃에 커밋됨.
# 실제 키는 .env 파일에 채우고, .env는 .gitignore에 의해 절대 커밋 안 됨.

# ─── Stage A ───
# ApeWisdom과 Stocktwits는 키 불필요 — 추가 설정 없음.

# ─── Phase 2.5 (Reddit 공식 API 티켓 승인 후) ───
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USER_AGENT=stock-trending-bot/0.1 by yourname

# ─── Stage B (X 자동 포스팅) ───
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_TOKEN_SECRET=

# ─── 공통 플래그 ───
# DRY_RUN=true   # true면 트윗 실제 게시 안 하고 콘솔에 미리보기만
